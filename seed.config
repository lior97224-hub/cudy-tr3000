# 精准锁死 Cudy TR3000 v1 硬件方案
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_cudy_tr3000-v1=y

# 极限瘦身：强行关闭默认的大型多余插件，确保 128M 闪存安全
# [!] 彻底砍掉不需要的共享、打印、Docker、多余主题等
CONFIG_PACKAGE_luci-app-accesscontrol=isnotset
CONFIG_PACKAGE_luci-app-wol=isnotset
CONFIG_PACKAGE_luci-app-vsftpd=isnotset
CONFIG_PACKAGE_luci-theme-bootstrap=y

# 精准集成 Passwall 2 与其唯一核心 Xray
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y
CONFIG_PACKAGE_xray-core=y
